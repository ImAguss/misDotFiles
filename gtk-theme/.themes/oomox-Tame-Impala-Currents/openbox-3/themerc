# Menu
menu.border.color: #e6e1eb

menu.title.bg: Solid Flat
menu.title.bg.color: #2a2232
menu.title.bg.shadow: 0
menu.title.text.color: #e6e1eb
menu.title.text.justify: Center

menu.items.bg: Solid Flat
menu.items.bg.color: #2a2232
menu.items.text.color: #e6e1eb
menu.items.disabled.text.color: #b7b1bc

menu.items.active.bg: Solid Flat
menu.items.active.bg.color: #6f4683
menu.items.active.text.color: #e6e1eb

menu.separator.color: #b7b1bc
menu.separator.width: 1
menu.separator.padding.width: 2
menu.separator.padding.height: 4

# Window focused
window.active.title.separator.color: #2a2232

# Active window
window.active.border.color: #b58ac6


window.active.title.bg: flat solid
window.active.title.bg.color: #2a2232
window.active.title.separator.color: #2a2232
window.active.text.justify: center

window.active.label.bg: parentrelative
window.active.label.text.color: #e6e1eb

window.active.handle.bg: flat solid
window.active.handle.bg.color: #2a2232

window.active.grip.bg: flat solid
window.active.grip.bg.color: #2a2232

window.active.button.unpressed.bg: flat solid
window.active.button.unpressed.bg.color: #2a2232
window.active.button.unpressed.image.color: #e6e1eb

window.active.button.pressed.bg: flat solid
window.active.button.pressed.bg.color: #6f4683
window.active.button.pressed.image.color: #ffffff

window.active.button.disabled.bg: flat solid
window.active.button.disabled.bg.color: #2a2232
window.active.button.disabled.image.color: #b7b1bc

window.active.button.hover.bg: flat solid
window.active.button.hover.bg.color: #2a2232
window.active.button.hover.image.color: #6f4683

#window.active.button.toggled.bg: #6f4683
#window.active.button.toggled.image.color: #ffffff

# Inactive window
window.inactive.border.color: #2a2232

window.inactive.title.bg: flat solid
window.inactive.title.bg.color: #2a2232
window.inactive.title.separator.color: #2a2232
window.inactive.text.justify: center

window.inactive.label.bg: parentrelative
window.inactive.label.text.color: #b7b1bc

window.inactive.handle.bg: flat solid
window.inactive.handle.bg.color: #2a2232

window.inactive.grip.bg: flat solid
window.inactive.grip.bg.color: #2a2232

window.inactive.button.unpressed.bg: flat solid
window.inactive.button.unpressed.bg.color: #2a2232
window.inactive.button.unpressed.image.color: #b7b1bc

window.inactive.button.pressed.bg: flat solid
window.inactive.button.pressed.bg.color: #6f4683
window.inactive.button.pressed.image.color: #ffffff

window.inactive.button.disabled.bg: flat solid
window.inactive.button.disabled.bg.color: #b7b1bc
window.inactive.button.disabled.image.color: #2a2232

window.inactive.button.hover.bg: flat solid
window.inactive.button.hover.bg.color: #2a2232
window.inactive.button.hover.image.color: #6f4683


# OSD
osd.border.width: 1
osd.border.color: #6f4683

osd.bg: flat solid
osd.bg.color: #2a2232
osd.label.bg: flat solid
osd.label.bg.color: #2a2232
osd.label.text.color: #e6e1eb

# OSD
osd.bg: Solid Flat
osd.bg.color: #2a2232
osd.bg.shadow: 0

osd.border.width: 2
osd.hilight.bg: Solid Flat
osd.hilight.bg.color: #6f4683
osd.unhilight.bg: flat solid
osd.unhilight.bg.color: #1f1a24

osd.button.unpressed.bg: flat border
osd.button.unpressed.bg.color: #e23e64
#osd.button.unpressed.*.border.color: #e6e1eb

osd.button.pressed.bg: flat border
osd.button.pressed.bg.color: #6f4683
#osd.button.pressed.*.border.color: #ffffff

osd.button.focused.bg: flat solid border
osd.button.focused.bg.color: #e6e1eb
#osd.button.focused.*.border.color: #1f1a24

osd.button.focused.box.color: #6f4683


# Fonts
window.active.label.text.font:shadow=n
window.inactive.label.text.font:shadow=n
menu.items.font:shadow=n
menu.title.text.font:shadow=n


# Everything else
border.width: 3
padding.width: 8
padding.height: 3
window.handle.width: 0
window.client.padding.width: 0
window.label.text.justify: center
#menu.overlap: 0
